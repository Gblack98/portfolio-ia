---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const getStaticPaths = (async () => {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title={data.title} description={data.description}>
  <article class="mx-auto max-w-3xl px-5 py-16">
    <a href="/projets" class="inline-flex items-center gap-1 text-sm font-medium text-brand-600 hover:underline dark:text-brand-400">
      ← Retour aux projets
    </a>

    <header class="mt-6">
      <div class="flex flex-wrap gap-2">
        {data.tags.map((tag) => (
          <span class="rounded-md bg-brand-50 px-2.5 py-1 text-xs font-medium text-brand-600 dark:bg-brand-500/10 dark:text-brand-400">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight sm:text-5xl">{data.title}</h1>
      <p class="mt-4 text-xl text-slate-500 dark:text-slate-400">{data.description}</p>
      <p class="mt-3 text-sm text-slate-400">{fmt(data.date)}</p>

      {(data.demo || data.repo) && (
        <div class="mt-6 flex flex-wrap gap-3">
          {data.demo && (
            <a href={data.demo} target="_blank" rel="noopener noreferrer" class="rounded-full bg-gradient-brand px-5 py-2.5 text-sm font-semibold text-white transition hover:-translate-y-0.5">
              🚀 Démo en ligne
            </a>
          )}
          {data.repo && (
            <a href={data.repo} target="_blank" rel="noopener noreferrer" class="rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold transition hover:border-brand-300 dark:border-slate-700">
              💻 Code source
            </a>
          )}
        </div>
      )}
    </header>

    {
      data.cover && (
        <Image
          src={data.cover}
          alt={data.title}
          width={1200}
          height={750}
          class="mt-10 w-full rounded-2xl border border-slate-200 dark:border-slate-800"
        />
      )
    }

    <div class="prose-content mt-10">
      <Content />
    </div>
  </article>
</BaseLayout>
