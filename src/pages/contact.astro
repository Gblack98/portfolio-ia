---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../site';

// 👉 Crée un formulaire gratuit sur https://formspree.io et colle ton ID ici.
// Tant que c'est vide, le formulaire bascule en lien mailto.
const FORMSPREE_ID = ''; // ex: 'xqkزabcd'
const formAction = FORMSPREE_ID ? `https://formspree.io/f/${FORMSPREE_ID}` : '';

const socialLinks = Object.entries(SITE.socials).filter(([, url]) => url);
---

<BaseLayout title="Contact" description="Discutons de votre projet Data ou IA.">
  <section class="mx-auto max-w-5xl px-5 py-20">
    <div class="grid gap-12 lg:grid-cols-2">
      <!-- Colonne info -->
      <div data-reveal>
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
          Travaillons <span class="text-gradient">ensemble</span>
        </h1>
        <p class="mt-5 text-lg text-slate-500 dark:text-slate-400">
          Une mission, une collaboration ou simplement une question ? Écrivez-moi, je réponds sous 48h.
        </p>

        <div class="mt-8 space-y-4">
          <a href={`mailto:${SITE.email}`} class="flex items-center gap-3 text-slate-700 hover:text-brand-600 dark:text-slate-200">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-500 dark:bg-brand-500/10">✉️</span>
            {SITE.email}
          </a>
          <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="flex items-center gap-3 text-slate-700 hover:text-brand-600 dark:text-slate-200">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-500 dark:bg-brand-500/10">📞</span>
            {SITE.phone}
          </a>
          <p class="flex items-center gap-3 text-slate-700 dark:text-slate-200">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-500 dark:bg-brand-500/10">📍</span>
            {SITE.location}
          </p>
        </div>

        {socialLinks.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-3">
            {socialLinks.map(([name, url]) => (
              <a href={url} target="_blank" rel="noopener noreferrer" class="rounded-full border border-slate-200 px-4 py-2 text-sm font-medium capitalize transition hover:border-brand-300 hover:text-brand-500 dark:border-slate-700">
                {name}
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Colonne formulaire -->
      <div data-reveal style="--reveal-delay: 120ms" class="rounded-3xl border border-slate-200 bg-white p-7 shadow-xl shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-900 dark:shadow-none">
        <form
          action={formAction}
          method="POST"
          class="space-y-5"
          data-has-action={FORMSPREE_ID ? 'true' : 'false'}
          data-email={SITE.email}
        >
          <div>
            <label for="name" class="mb-1.5 block text-sm font-medium">Nom</label>
            <input id="name" name="name" type="text" required
              class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-400/30 dark:border-slate-700 dark:bg-slate-800" />
          </div>
          <div>
            <label for="email" class="mb-1.5 block text-sm font-medium">E-mail</label>
            <input id="email" name="email" type="email" required
              class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-400/30 dark:border-slate-700 dark:bg-slate-800" />
          </div>
          <div>
            <label for="message" class="mb-1.5 block text-sm font-medium">Message</label>
            <textarea id="message" name="message" rows="5" required
              class="w-full resize-y rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-400/30 dark:border-slate-700 dark:bg-slate-800"></textarea>
          </div>
          <button type="submit"
            class="w-full rounded-xl bg-gradient-brand py-3.5 font-semibold text-white shadow-lg shadow-brand-500/25 transition hover:-translate-y-0.5 hover:shadow-brand-500/40">
            Envoyer le message
          </button>
          <p id="form-note" class="text-center text-sm text-slate-400"></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Sans clé Formspree configurée : on bascule proprement sur un lien mailto.
  function setupForm() {
    const form = document.querySelector<HTMLFormElement>('form[data-has-action]');
    if (!form) return;
    if (form.dataset.hasAction === 'true') return; // Formspree gère l'envoi

    const note = document.getElementById('form-note');
    if (note) {
      note.textContent = '💡 Astuce : configure ton ID Formspree dans contact.astro pour recevoir les messages par e-mail.';
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const subject = encodeURIComponent(`Contact portfolio — ${data.get('name')}`);
      const body = encodeURIComponent(`${data.get('message')}\n\n— ${data.get('name')} (${data.get('email')})`);
      window.location.href = `mailto:${form.dataset.email}?subject=${subject}&body=${body}`;
    });
  }
  setupForm();
  document.addEventListener('astro:page-load', setupForm);
</script>
