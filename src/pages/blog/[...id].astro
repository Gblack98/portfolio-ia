---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);

const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title={data.title} description={data.description}>
  <article class="mx-auto max-w-3xl px-5 py-16">
    <a href="/blog" class="inline-flex items-center gap-1 text-sm font-medium text-brand-600 hover:underline dark:text-brand-400">
      ← Retour au blog
    </a>

    <header class="mt-6">
      <div class="flex flex-wrap gap-2">
        {data.tags.map((tag) => (
          <span class="rounded-md bg-brand-50 px-2.5 py-1 text-xs font-medium text-brand-600 dark:bg-brand-500/10 dark:text-brand-400">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight sm:text-5xl">{data.title}</h1>
      <div class="mt-4 flex items-center gap-2 text-sm text-slate-400">
        <span>Par {data.author}</span>
        <span>·</span>
        <span>{fmt(data.date)}</span>
        {data.updatedDate && <span>· maj {fmt(data.updatedDate)}</span>}
      </div>
    </header>

    {
      data.cover && (
        <Image
          src={data.cover}
          alt={data.title}
          width={1200}
          height={750}
          class="mt-10 w-full rounded-2xl border border-slate-200 dark:border-slate-800"
        />
      )
    }

    <div class="prose-content mt-10">
      <Content />
    </div>
  </article>
</BaseLayout>
