---
import { SITE } from '../site';
const year = new Date().getFullYear();

const socialLinks = Object.entries(SITE.socials).filter(([, url]) => url);
---

<footer class="border-t border-slate-200/60 bg-slate-50/50 dark:border-slate-800/60 dark:bg-slate-900/30">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="flex flex-col items-center gap-6 text-center md:flex-row md:justify-between md:text-left">
      <div>
        <p class="text-lg font-bold">{SITE.name}</p>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{SITE.role}</p>
      </div>

      <div class="flex items-center gap-3">
        {
          socialLinks.map(([name, url]) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border border-slate-200 px-4 py-2 text-sm font-medium capitalize text-slate-600 transition hover:border-brand-300 hover:text-brand-500 dark:border-slate-700 dark:text-slate-300"
            >
              {name}
            </a>
          ))
        }
      </div>
    </div>

    <div class="mt-8 border-t border-slate-200/60 pt-6 text-center text-sm text-slate-400 dark:border-slate-800/60">
      © {year} {SITE.name}. Conçu avec Astro & Tailwind CSS.
    </div>
  </div>
</footer>
